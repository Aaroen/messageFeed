# messageFeed 环境变量配置示例
# 复制本文件为 .env 并根据实际环境修改配置值。
# 注意：.env 文件包含敏感信息，不应提交到版本控制系统。

# ==================== HTTP 服务配置 ====================

# BIND_ADDR 是 HTTP 服务实际监听的地址和端口。
# 本地开发：127.0.0.1:60001（仅本机可访问）
# 局域网访问：0.0.0.0:60001（局域网内设备可访问）
# Tailscale：<Tailscale_IP>:60001 或 0.0.0.0:60001
BIND_ADDR=127.0.0.1:60001

# PUBLIC_BASE_URL 是用户或外部系统访问服务时使用的公开基址。
# 本地开发：http://127.0.0.1:60001
# Tailscale：http://<Tailscale_IP>:60001 或 http://<MagicDNS>:60001
# 生产环境：https://messagefeed.yourdomain.com
PUBLIC_BASE_URL=http://127.0.0.1:60001

# ==================== 运行时配置 ====================

# APP_NODE_ID 是当前节点的唯一标识。
# 单节点部署可使用默认值；多节点部署时每个节点应设置不同的稳定标识。
APP_NODE_ID=local-dev

# DEPLOYMENT_MODE 表示部署拓扑，当前支持 single_node 和 cluster。
# single_node：服务、调度器和数据库位于同一节点
# cluster：多节点部署，共享 PostgreSQL，需配置任务锁和幂等机制
DEPLOYMENT_MODE=single_node

# TRUSTED_PROXY_CIDRS 是可信代理网段列表，使用英文逗号分隔。
# 当服务位于反向代理或 Cloudflare 后时，需配置可信来源以正确提取客户端 IP。
# 示例：TRUSTED_PROXY_CIDRS=100.64.0.0/10,192.168.0.0/16
# 第一阶段可留空。
TRUSTED_PROXY_CIDRS=

# ==================== 日志配置 ====================

# LOG_LEVEL 是日志级别，支持 debug、info、warn、error。
# 开发环境建议使用 debug 或 info，生产环境建议使用 info 或 warn。
LOG_LEVEL=info

# ==================== 数据库配置（阶段一后期接入）====================

# DATABASE_URL 是 PostgreSQL 连接字符串。
# 格式：postgres://用户名:密码@主机:端口/数据库名?sslmode=disable
# 示例：DATABASE_URL=postgres://messagefeed:password@localhost:5432/messagefeed?sslmode=disable
# 注意：生产环境应启用 SSL（sslmode=require）并使用强密码。
# DATABASE_URL=postgres://messagefeed:devpassword@localhost:5432/messagefeed?sslmode=disable

# DATABASE_MAX_OPEN_CONNS 是数据库连接池最大连接数。
# 默认值通常为 25，根据实际负载调整。
# DATABASE_MAX_OPEN_CONNS=25

# DATABASE_MAX_IDLE_CONNS 是数据库连接池最大空闲连接数。
# 默认值通常为 5，建议设置为 max_open_conns 的 20%-40%。
# DATABASE_MAX_IDLE_CONNS=5

# DATABASE_CONN_MAX_LIFETIME 是单个数据库连接的最大生命周期（秒）。
# 默认值通常为 3600（1小时），避免连接长期占用。
# DATABASE_CONN_MAX_LIFETIME=3600

# ==================== Redis 配置（后续阶段接入）====================

# REDIS_URL 是 Redis 连接字符串。
# 格式：redis://[:密码@]主机:端口/数据库编号
# 示例：REDIS_URL=redis://:password@localhost:6379/0
# 注意：Redis 密码为空时可省略 :密码@ 部分。
# REDIS_URL=redis://localhost:6379/0

# ==================== 通知通道配置（阶段五接入）====================

# NTFY_URL 是 ntfy 推送服务地址。
# 使用官方服务：https://ntfy.sh
# 自建服务：https://your-ntfy-instance.com
# NTFY_URL=https://ntfy.sh

# NTFY_TOPIC 是 ntfy 推送主题。
# 建议使用随机 UUID 或长随机字符串，避免被他人订阅。
# NTFY_TOPIC=

# WECHAT_WEBHOOK_URL 是企业微信机器人 Webhook 地址。
# 从企业微信管理后台获取，格式：https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...
# WECHAT_WEBHOOK_URL=

# ==================== AI 模型配置（阶段五接入）====================

# LLM_PROVIDER 是大模型提供商，支持 openai、anthropic、azure 等。
# LLM_PROVIDER=openai

# LLM_API_KEY 是大模型 API 密钥。
# 注意：该密钥具有调用成本，务必妥善保管，不要提交到版本控制系统。
# LLM_API_KEY=

# LLM_BASE_URL 是大模型 API 基址（可选）。
# OpenAI 兼容接口或自建模型服务时需配置。
# LLM_BASE_URL=

# LLM_MODEL 是默认使用的模型名称。
# OpenAI 示例：gpt-4-turbo、gpt-3.5-turbo
# Anthropic 示例：claude-3-opus-20240229、claude-3-sonnet-20240229
# LLM_MODEL=gpt-4-turbo

# ==================== 金融行情配置（阶段七接入）====================

# MARKET_DATA_PROVIDER 是金融行情数据源。
# 支持：yahoo_finance、alpha_vantage、finnhub、tushare、akshare
# MARKET_DATA_PROVIDER=yahoo_finance

# MARKET_DATA_API_KEY 是行情数据源 API 密钥（部分提供商需要）。
# Alpha Vantage、Finnhub 等需要注册并获取 API Key。
# MARKET_DATA_API_KEY=

# ==================== 其他配置 ====================

# TZ 是时区配置，影响日志时间戳和定时任务触发时间。
# 建议使用 UTC 或本地时区（如 Asia/Shanghai）。
TZ=UTC
