{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$comment": "校验 messageFeed Helm values 的关键字段与约束。",
  "type": "object",
  "properties": {
    "storageClass": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "reclaimPolicy": { "type": "string", "enum": ["Retain", "Delete"] },
        "volumeBindingMode": { "type": "string", "enum": ["Immediate", "WaitForFirstConsumer"] }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "const": 1 }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string", "minLength": 1 },
            "database": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "cloudflared": {
      "type": "object",
      "properties": {
        "protocol": { "type": "string", "enum": ["auto", "quic", "http2"] }
      }
    }
  }
}
