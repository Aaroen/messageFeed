{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$comment": "校验 messageFeed Helm values 的关键字段与约束。",
  "type": "object",
  "properties": {
    "scheduling": {
      "type": "object",
      "properties": {
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "topologySpread": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "maxSkew": { "type": "integer", "minimum": 1 },
            "topologyKey": { "type": "string", "minLength": 1 },
            "whenUnsatisfiable": { "type": "string", "enum": ["DoNotSchedule", "ScheduleAnyway"] }
          }
        },
        "podAntiAffinity": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "weight": { "type": "integer", "minimum": 1, "maximum": 100 },
            "topologyKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "defaultDeny": { "type": "boolean" },
        "gatewayIngressCIDRs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "observabilityIngressCIDRs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "kubernetesAPI": {
          "type": "object",
          "properties": {
            "serviceCIDR": { "type": "string", "minLength": 1 },
            "nodeCIDRs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
          }
        },
        "httpsEgress": { "type": "array", "items": { "$ref": "#/definitions/egressRule" } },
        "feedEgress": { "type": "array", "items": { "$ref": "#/definitions/egressRule" } },
        "llmEgress": { "type": "array", "items": { "$ref": "#/definitions/egressRule" } },
        "cloudflaredEgress": { "type": "array", "items": { "$ref": "#/definitions/egressRule" } }
      }
    },
    "resourceGovernance": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "quota": {
          "type": "object",
          "properties": {
            "pods": { "type": "string", "pattern": "^[1-9][0-9]*$" },
            "requestsCPU": { "type": "string", "minLength": 1 },
            "requestsMemory": { "type": "string", "minLength": 1 },
            "limitsCPU": { "type": "string", "minLength": 1 },
            "limitsMemory": { "type": "string", "minLength": 1 },
            "persistentvolumeclaims": { "type": "string", "pattern": "^[1-9][0-9]*$" },
            "requestsStorage": { "type": "string", "minLength": 1 }
          }
        },
        "limitRange": {
          "type": "object",
          "properties": {
            "defaultCPU": { "type": "string", "minLength": 1 },
            "defaultMemory": { "type": "string", "minLength": 1 },
            "defaultRequestCPU": { "type": "string", "minLength": 1 },
            "defaultRequestMemory": { "type": "string", "minLength": 1 },
            "minCPU": { "type": "string", "minLength": 1 },
            "minMemory": { "type": "string", "minLength": 1 },
            "maxCPU": { "type": "string", "minLength": 1 },
            "maxMemory": { "type": "string", "minLength": 1 }
          }
        },
        "pdb": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minAvailable": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "storageClass": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "reclaimPolicy": { "type": "string", "enum": ["Retain", "Delete"] },
        "volumeBindingMode": { "type": "string", "enum": ["Immediate", "WaitForFirstConsumer"] }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": {
          "type": "object",
          "properties": {
            "tag": { "type": "string", "minLength": 1, "not": { "const": "latest" } }
          }
        }
      }
    },
    "workers": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "bindAddr": { "type": "string", "pattern": "^[^:]+:[0-9]+$" }
          }
        },
        "source": { "$ref": "#/definitions/worker" },
        "notification": { "$ref": "#/definitions/worker" },
        "agentScheduler": { "$ref": "#/definitions/worker" },
        "embedding": { "$ref": "#/definitions/worker" }
      }
    },
    "migrations": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string", "const": "migrations" },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "appConfig": {
      "type": "object",
      "properties": {
        "deploymentMode": { "type": "string", "enum": ["single_node", "cluster"] },
        "defaultAppRole": {
          "type": "string",
          "enum": ["all", "api", "source-worker", "notification-worker", "agent-scheduler-worker", "embedding-worker", "migrate"]
        },
        "databaseMaxOpenConns": { "type": "string", "pattern": "^[1-9][0-9]*$" },
        "databaseMaxIdleConns": { "type": "string", "pattern": "^[0-9]+$" }
      }
    },
    "web": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "tag": { "type": "string", "minLength": 1, "not": { "const": "latest" } }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string", "minLength": 1 },
            "database": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "cloudflared": {
      "type": "object",
      "properties": {
        "protocol": { "type": "string", "enum": ["auto", "quic", "http2"] },
        "image": {
          "type": "object",
          "properties": {
            "tag": { "type": "string", "minLength": 1, "not": { "const": "latest" } }
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "grafana": {
          "type": "object",
          "properties": {
            "existingSecret": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  },
  "definitions": {
    "egressRule": {
      "type": "object",
      "required": ["cidr", "ports"],
      "properties": {
        "cidr": { "type": "string", "minLength": 1 },
        "except": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 }
        }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" }
      }
    }
  }
}
